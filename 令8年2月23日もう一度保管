                        Link("隐私政策", destination: URL(string: "https://trapezoidal-partridge-6ad.notion.site/Doujitu-2b0ab0596b9880d68f09e3757b41f160?pvs=143")!)
                        Link("使用条款 (EULA)", destination: URL(string: "https://www.apple.com/legal/internet-services/itunes/dev/stdeula/")!)
                        Spacer()
                    }
                    .font(.system(size: 12))
                    .foregroundColor(.orange)
                }
                .padding(.horizontal)
                .padding(.vertical, 8)
                .background(Color(.systemGroupedBackground))
                VStack(spacing: 8) {
